### Get roles associated with a specific user.
# Description:
# - Retrieves all roles assigned to the user identified by `userId`.
# - Supports filtering by role name and sorting.
# - Requires ROLE_ADMIN or ROLE_MODERATOR.

GET http://localhost:8444/api/v1/table/user-roles/1?roleNameFilter=&sortBy=roleId&sortOrder=asc
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
Accept: application/hal+json

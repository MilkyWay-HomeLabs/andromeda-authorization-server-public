### Get a specific user-role assignment by ID.
# Description:
# - Retrieves details of a single user-role mapping.
# - Requires ROLE_ADMIN, ROLE_TESTER, or ROLE_MODERATOR.

GET http://localhost:8444/api/v1/table/user-role/1
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
Accept: application/hal+json

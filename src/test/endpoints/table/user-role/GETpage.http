### Get a paginated list of user-role assignments.
# Description:
# - Retrieves a page of user-role mappings.
# - Requires ROLE_ADMIN, ROLE_TESTER, or ROLE_MODERATOR.

GET http://localhost:8444/api/v1/table/user-role?page=0&size=20&sortBy=userId&sortOrder=asc
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
Accept: application/hal+json

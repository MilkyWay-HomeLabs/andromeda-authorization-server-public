### Get a paginated list of refresh tokens.
# Description:
# - Retrieves a page of refresh tokens with optional filtering and sorting.
# - Requires ROLE_ADMIN, ROLE_TESTER, or ROLE_MODERATOR.

GET http://localhost:8444/api/v1/table/tokens/refresh?page=0&size=20&sortBy=userId&sortOrder=asc&usernameFilter=&emailFilter=
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
Accept: application/hal+json

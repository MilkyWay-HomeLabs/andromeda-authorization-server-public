### Check if an access token is valid.
# Description:
# - Verifies if the provided access token is still valid.
# - Requires ROLE_ADMIN, ROLE_TESTER, or ROLE_MODERATOR.

GET http://localhost:8444/api/v1/table/tokens/access/valid/YOUR_ACCESS_TOKEN_HERE
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
Accept: application/hal+json

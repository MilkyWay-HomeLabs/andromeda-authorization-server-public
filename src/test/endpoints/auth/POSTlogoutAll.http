### Endpoint for user logout from all sessions.
# Description:
# - This endpoint is used to invalidate all refresh tokens for the authenticated user and clear authentication cookies.
# - A valid `Authorization` Bearer token is required.

# Endpoint URL:
# - Localhost (for testing): http://localhost:8444/api/v1/auth/logout-all

POST http://localhost:8444/api/v1/auth/logout-all
X-Requesting-App: nebula_rest_api
Authorization: Bearer YOUR_ACCESS_TOKEN_HERE
